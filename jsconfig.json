{
  // Static type-checking for plain JS/JSX via JSDoc. `tsc --checkJs` reads this
  // config and verifies types without any .ts files or a build step, giving the
  // "statically verified" guarantee while the app stays in idiomatic React JS.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "coverage", "**/*.test.js", "**/*.test.jsx"]
}
